# Backend
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.db
backend/.env

# Frontend
frontend/node_modules/
frontend/.next/
frontend/.env.local
frontend/.env

# Runtime artifacts: train_body.sh regenerates these on every run, so they
# should never be tracked — would just create constant noise in `git status`
# after each cluster job.
configs/experiments/*/data_config.yaml

# Variant configs are per-user / per-experiment; only the _sample/ template
# ships in git so newcomers have a starting reference.
configs/experiments/*
!configs/experiments/_sample/
!configs/experiments/_sample/**
!configs/experiments/physixel_cube_stack_3cm_right_480/
!configs/experiments/physixel_cube_stack_3cm_right_480/**

# Local scratch
.DS_Store
*.bak
*.bak.*
