MODEL_LABEL="DexJoCo (pi0.5 baseline)"
MODEL_FAMILY=n1.6
FLAGS_PROFILE=n1.6
ACTION_HORIZON_MODE=none
# Eval-only: the released pi0.5 checkpoint is served via openpi (no GR00T training).
# SLURM_REPO_VAR points at the dexjoco repo so submit pins the patched openpi/eval-client
# commit. TRAIN_BODY_SCRIPT is required by the model schema but unused (no train phase).
SLURM_REPO_VAR=DEXJOCO_DIR
MLXP_REPO_DIR="${DDN_USER_HOME}/workspace/dexjoco"
TRAIN_BODY_SCRIPT=train_body_n16.sh
EVAL_BODY_SCRIPT=eval_body_dexjoco.sh
TRAIN_WALLTIME=02:00:00
EVAL_WALLTIME=02:00:00
