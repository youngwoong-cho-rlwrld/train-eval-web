# SKT (AWS ParallelCluster, us-east-1) cluster config
# Sourced by submit + lib/{train,eval}_body.sh after CLUSTER is set to 'skt'.
export CLUSTER=skt
export PARTITION=l40s-gpu
export REPO_ROOT=/fsx/rlwrld/youngwoong_cho/train-eval-scripts
export GROOT_DIR=/fsx/rlwrld/youngwoong_cho/workspace/gr00t
export GROOT_N16_DIR=/fsx/rlwrld/youngwoong_cho/workspace/gr00t-n16
export PHYSIXEL_DIR=/fsx/rlwrld/youngwoong_cho/workspace/physixel
export ISAAC_DIR=/fsx/rlwrld/youngwoong_cho/workspace/rlwrld_isaac
export DATA_DIR=/fsx/rlwrld/youngwoong_cho/datasets/v4
export LOG_DIR=/fsx/rlwrld/youngwoong_cho/logs

##########################################################################
# BELOW IS A MANUALLY EXCLUDED NODE. SUBJECT TO CHANGE IF THINGS CHANGE. #
##########################################################################
# Slurm still reports this node as schedulable, but Isaac Sim repeatedly
# fails there with CUDA bad state / Vulkan ERROR_DEVICE_LOST during startup.
export SBATCH_EXCLUDE=rlwrld-gpu-260504-260803-st-p5en-48xl-1,rlwrld-gpu-260504-260803-st-p5en-48xl-3

# torchcodec 0.1.0 + patched libtorchcodec6 needs ffmpeg 6.1 shared libs from
# the local install at $GROOT_DIR/.venv/ffmpeg6/. Without this prefix, the
# dynamic linker falls back to system libav (older), and AV1 mp4 decode breaks
# in dataloader workers.
export LD_LIBRARY_PATH="$GROOT_DIR/.venv/ffmpeg6/lib:${LD_LIBRARY_PATH:-}"
