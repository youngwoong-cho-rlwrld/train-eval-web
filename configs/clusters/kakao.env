# Kakao cluster env template.
# Configure user-specific values from the Settings page.
export CLUSTER=kakao
export SSH_ALIAS=
export PARTITION=
export REPO_ROOT=
export GROOT_DIR=
export GROOT_N16_DIR=
export PHYSIXEL_DIR=
export ISAAC_DIR=
export DATA_DIR=
export LOG_DIR=
export SBATCH_EXCLUDE=
export SLURM_EXCLUDE_NODES=
export LD_LIBRARY_PATH=

# DexJoCo (MuJoCo benchmark) eval harness - used by lib/eval_body_dexjoco.sh.
# DEXJOCO_DIR holds the eval client, task configs (configs/<family>/<task>.yaml),
# and the released pi0.5 checkpoints (checkpoints/pi05_dexjoco_ckpt/<task>).
export DEXJOCO_DIR=
export MICROMAMBA_BIN=
export MAMBA_ROOT_PREFIX=
export DEXJOCO_EVAL_ENV=
export DEXJOCO_OPENPI_ENV=
